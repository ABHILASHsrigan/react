{
  "name": "todo-list-app",
  "version": "1.0.0",
  "description": "A Todo List application with CRUD operations using Axios and JSON-Server",
  "main": "index.html",
  "scripts": {
    "start": "json-server --watch db.json --port 3000",
    "dev": "concurrently \"npm run start\" \"python -m http.server 8080\"",
    "serve": "python -m http.server 8080"
  },
  "dependencies": {
    "json-server": "^0.17.4"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "keywords": [
    "todo",
    "crud",
    "axios",
    "json-server",
    "javascript"
  ],
  "author": "",
  "license": "MIT"
}
